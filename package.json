{
  "name": "tiki-acca",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@tiki-acca/web",
    "dev:mobile": "npm run dev --workspace=@tiki-acca/mobile",
    "build": "npm run build --workspace=@tiki-acca/web",
    "lint": "npm run check:brand && npm run lint --workspace=@tiki-acca/web",
    "check:brand": "node scripts/check-brand-sync.mjs",
    "generate:brand-assets": "node scripts/generate-brand-assets.mjs",
    "marketing:seed": "cd packages/database && npx tsx prisma/demo-seed.ts",
    "marketing:capture": "node marketing-posts/scripts/capture-panels.mjs",
    "marketing:build": "node marketing-posts/scripts/make-posts.mjs",
    "marketing:gallery": "node marketing-posts/scripts/build-gallery.mjs",
    "marketing:x-header": "node marketing-posts/scripts/make-x-header.mjs",
    "db:generate": "npm run generate --workspace=@tiki-acca/database",
    "db:migrate": "npm run migrate --workspace=@tiki-acca/database",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=@tiki-acca/database",
    "db:push": "npm run push --workspace=@tiki-acca/database",
    "db:seed": "npm run seed --workspace=@tiki-acca/database",
    "db:maintenance": "npm run db:maintenance --workspace=@tiki-acca/web",
    "build:mobile:preview": "npm run build:preview:ios --workspace=@tiki-acca/mobile"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "playwright": "1.61.1",
    "sharp": "0.34.5"
  }
}
