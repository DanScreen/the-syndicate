{
  "name": "the-syndicate",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@the-syndicate/web",
    "dev:mobile": "npm run dev --workspace=@the-syndicate/mobile",
    "build": "npm run build --workspace=@the-syndicate/web",
    "lint": "npm run lint --workspace=@the-syndicate/web",
    "db:generate": "npm run generate --workspace=@the-syndicate/database",
    "db:migrate": "npm run migrate --workspace=@the-syndicate/database",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=@the-syndicate/database",
    "db:push": "npm run push --workspace=@the-syndicate/database",
    "db:seed": "npm run seed --workspace=@the-syndicate/database",
    "db:maintenance": "npm run db:maintenance --workspace=@the-syndicate/web",
    "build:mobile:preview": "npm run build:preview:ios --workspace=@the-syndicate/mobile"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
