{
  "name": "the-syndicate",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@the-syndicate/web",
    "build": "npm run build --workspace=@the-syndicate/web",
    "lint": "npm run lint --workspace=@the-syndicate/web",
    "db:generate": "npm run generate --workspace=@the-syndicate/database",
    "db:migrate": "npm run migrate --workspace=@the-syndicate/database",
    "db:push": "npm run push --workspace=@the-syndicate/database",
    "db:seed": "npm run seed --workspace=@the-syndicate/database"
  }
}
