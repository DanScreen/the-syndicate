DATABASE_URL="postgresql://syndicate:syndicate@localhost:5432/the_syndicate"
AUTH_SECRET="dev-secret-change-in-production-the-syndicate-2026"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# The Odds API (https://the-odds-api.com/) — omit to use mock fixtures
# ODDS_API_KEY="your-api-key"
# ODDS_API_SPORT="soccer_fifa_world_cup"
# ODDS_API_REGIONS="uk"
# ODDS_API_CACHE_TTL_MS="1800000"
# ODDS_DB_ONLY="true"
# ODDS_WARM_CORE_WITHIN_HOURS="72"

# football-data.org (https://www.football-data.org/) — match sync + auto-settle
# FOOTBALL_DATA_API_KEY="your-api-key"
# FOOTBALL_DATA_CACHE_TTL_MS="60000"

# Email notifications (Resend — https://resend.com/) — omit to skip emails
# RESEND_API_KEY="re_..."
# EMAIL_FROM="The Syndicate <notifications@the-syndicate.uk>"

# Cron secret for POST /api/internal/sync-matches (Cloud Scheduler)
# CRON_SECRET="generate-a-long-random-string"

# Comma-separated developer emails granted platform admin ( /admin dashboard )
# ADMIN_EMAILS="you@example.com,teammate@example.com"

# Optional: single allowed origin for API CORS in production
# ALLOWED_ORIGIN="https://the-syndicate.example.com"

# Optional: block direct-to-Cloud-Run traffic that bypasses Cloudflare.
# Set the same value in a Cloudflare Transform Rule that adds the
# x-origin-auth request header. Unset = check disabled (local dev).
# See docs/DEPLOYMENT.md → "DDoS & abuse protection".
# ORIGIN_AUTH_SECRET="generate-a-long-random-string"
