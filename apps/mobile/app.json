{
  "expo": {
    "name": "The Syndicate",
    "slug": "the-syndicate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "the-syndicate",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1220"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thesyndicate.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:www.the-syndicate.uk"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b1220",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.thesyndicate.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.the-syndicate.uk",
              "pathPrefix": "/groups"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://www.the-syndicate.uk"
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#22c55e"
        }
      ]
    ],
    "experiments": {
      "autolinkingModuleResolution": true
    }
  }
}
