{
  "expo": {
    "name": "Tiki Acca",
    "owner": "the-syndicate",
    "slug": "tiki-acca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tikiacca",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#091422"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tikiacca.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:www.tikiacca.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#091422",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.tikiacca.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.tikiacca.com",
              "pathPrefix": "/groups"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://www.tikiacca.com"
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#38bdf8"
        }
      ]
    ],
    "experiments": {
      "autolinkingModuleResolution": true
    }
  }
}
