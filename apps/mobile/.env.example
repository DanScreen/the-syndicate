# iOS Simulator + local web API:
EXPO_PUBLIC_API_URL=http://localhost:3000

# Physical iPhone (Expo Go or device build) or testing against prod:
# EXPO_PUBLIC_API_URL=https://www.tikiacca.com
# Or: npm run dev:prod  (sets prod URL without editing this file)

# EAS cloud builds: EXPO_PUBLIC_API_URL is set per profile in eas.json
# Expo push tokens (run `eas init` to get your project ID):
# EAS_PROJECT_ID=your-eas-project-uuid
# Developer guide: apps/mobile/DEVELOPER_TESTING.md
