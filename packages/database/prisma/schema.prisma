generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("user")
  totalPoints  Float         @default(0)
  legsWon      Int           @default(0)
  legsLost     Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ownedGroups  Group[]       @relation("GroupOwner")
  memberships  GroupMember[]
  legs         Leg[]
  analyticsEvents AnalyticsEvent[]
}

model Group {
  id         String        @id @default(cuid())
  name       String
  inviteCode String        @unique
  sport      String        @default("football")
  maxMembers Int           @default(10)
  status     String        @default("open")
  ownerId    String
  owner      User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members    GroupMember[]
  rounds     Round[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member")
  points    Float    @default(0)
  legsWon   Int      @default(0)
  legsLost  Int      @default(0)
  joinedAt  DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Round {
  id              String   @id @default(cuid())
  groupId         String
  status          String   @default("collecting")
  combinedOdds    Float?
  bestBookmakerId String?
  accaBookmakerRankings Json?
  stakeGbp        Float    @default(10)
  profitLossGbp   Float?
  lockedAt        DateTime?
  settledAt       DateTime?
  lockedNotificationSentAt  DateTime?
  settledNotificationSentAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  legs            Leg[]
}

model Leg {
  id            String   @id @default(cuid())
  roundId       String
  userId        String
  fixtureId     String
  homeTeam      String
  awayTeam      String
  competitionId String   @default("world-cup")
  competition   String
  matchId       String?
  kickoff       DateTime
  marketType    String
  marketLabel   String
  selectionId   String
  selectionLabel String
  odds          Float
  bookmakerId   String
  bookmakerName String
  betslipUrl    String?
  bookmakerLinks Json?
  outcome       String   @default("pending")
  pointsAwarded Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match?   @relation(fields: [matchId], references: [id])

  @@unique([roundId, userId])
}

model Match {
  id             String    @id @default(cuid())
  competitionId  String
  kickoff        DateTime
  homeTeam       String
  awayTeam       String
  status         String    @default("SCHEDULED")
  homeGoals      Int?
  awayGoals      Int?
  externalOddsId String?   @unique
  externalDataId Int?      @unique
  lastSyncedAt   DateTime?
  legs           Leg[]

  @@index([competitionId, kickoff])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  userId    String?
  path      String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([createdAt])
}

model CompetitionSetting {
  id            String   @id @default(cuid())
  competitionId String   @unique
  enabled       Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}
