generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  /// Full display name (`firstName lastName`) for leaderboards, picks, emails.
  name         String
  email        String        @unique
  /// Date of birth captured at sign-up for 18+ age verification. Nullable so
  /// pre-existing accounts (created before this was collected) are grandfathered.
  dateOfBirth  DateTime?     @db.Date
  passwordHash String
  role         String        @default("user")
  totalPoints  Float         @default(0)
  legsWon      Int           @default(0)
  legsLost     Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ownedGroups  Group[]       @relation("GroupOwner")
  memberships  GroupMember[]
  legs         Leg[]
  analyticsEvents AnalyticsEvent[]
  pushDevices     PushDevice[]
  notificationPreference NotificationPreference?
  notificationLogs NotificationLog[]
  roundMessages    RoundMessage[]
  messageReactions MessageReaction[]
  mobileSessions   MobileSession[]
}

/// Revocable, non-expiring device session for the native app.
/// Only a SHA-256 hash of the bearer token is stored.
model MobileSession {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model Group {
  id             String        @id @default(cuid())
  name           String
  inviteCode     String        @unique
  sport          String        @default("football")
  maxMembers     Int           @default(10)
  /// Legs each member must submit per round (1–3). Applies to newly opened rounds.
  legsPerMember  Int           @default(1)
  /// Maximum simultaneous open or locked bets (1–5).
  maxActiveBets  Int           @default(1)
  status         String        @default("open")
  ownerId        String
  owner          User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members        GroupMember[]
  rounds         Round[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model GroupMember {
  id                String    @id @default(cuid())
  groupId           String
  userId            String
  role              String    @default("member")
  points            Float     @default(0)
  legsWon           Int       @default(0)
  legsLost          Int       @default(0)
  joinedAt          DateTime  @default(now())
  lastReadMessageAt DateTime?
  group             Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId, lastReadMessageAt])
}

model Round {
  id              String   @id @default(cuid())
  groupId         String
  /// Stable, group-scoped display number. Nullable for compatibility with direct test fixtures.
  betNumber       Int?
  status          String   @default("open")
  /// Snapshot of group.legsPerMember when this round opened.
  legsPerMember   Int      @default(1)
  combinedOdds    Float?
  bestBookmakerId String?
  accaBookmakerRankings Json?
  stakeGbp        Float    @default(10)
  profitLossGbp   Float?
  lockedAt        DateTime?
  settledAt       DateTime?
  lockedNotificationSentAt  DateTime?
  settledNotificationSentAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  legs            Leg[]
  messages        RoundMessage[]

  @@unique([groupId, betNumber])
  @@index([groupId, status, createdAt])
}

model Leg {
  id            String   @id @default(cuid())
  roundId       String
  userId        String
  /// 1-based slot within the member's quota for this round.
  legIndex      Int      @default(1)
  fixtureId     String
  homeTeam      String
  awayTeam      String
  competitionId String   @default("world-cup")
  competition   String
  matchId       String?
  kickoff       DateTime
  marketType    String
  marketLabel   String
  selectionId   String
  selectionLabel String
  odds          Float
  bookmakerId   String
  bookmakerName String
  betslipUrl    String?
  bookmakerLinks Json?
  outcome       String   @default("pending")
  pointsAwarded Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match?   @relation(fields: [matchId], references: [id])
  messages      RoundMessage[]

  @@unique([roundId, userId, legIndex])
}

model Match {
  id             String    @id @default(cuid())
  competitionId  String
  kickoff        DateTime
  homeTeam       String
  awayTeam       String
  status         String    @default("SCHEDULED")
  homeGoals      Int?
  awayGoals      Int?
  externalOddsId String?   @unique
  externalDataId Int?      @unique
  lastSyncedAt   DateTime?
  legs           Leg[]

  @@index([competitionId, kickoff])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  userId    String?
  path      String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([createdAt])
}

model CompetitionSetting {
  id            String   @id @default(cuid())
  competitionId String   @unique
  enabled       Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

/// Cached bulk fixture list (h2h, totals, spreads) per competition — refreshed by cron.
model OddsBulkSnapshot {
  competitionId String   @id
  sport         String
  regions       String
  fixtures      Json
  fetchedAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([expiresAt])
}

/// Cached per-event extended markets per tier — refreshed by cron.
model OddsEventSnapshot {
  competitionId String
  fixtureId     String
  tierId        String
  markets       Json
  fetchedAt     DateTime @default(now())
  expiresAt     DateTime

  @@id([competitionId, fixtureId, tierId])
  @@index([expiresAt])
}

model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  platform   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

model NotificationPreference {
  id                 String @id @default(cuid())
  userId             String @unique
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailPickReminder  Boolean @default(true)
  emailRoundLocked   Boolean @default(true)
  emailRoundSettled  Boolean @default(true)
  pushPickReminder   Boolean @default(true)
  pushRoundLocked    Boolean @default(true)
  pushRoundSettled   Boolean @default(true)
  pushChat           Boolean @default(true)
  updatedAt          DateTime @updatedAt
}

/// Round-scoped chat thread — user banter plus append-only system messages
/// written at event time by the round lifecycle (see specs/group-chat.md).
model RoundMessage {
  id        String   @id @default(cuid())
  roundId   String
  round     Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId    String?  // null for system messages
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  kind      String   // "user" | "system"
  body      String   // user text (max 500 chars) or system event copy
  eventType String?  // system only: leg_submitted | leg_changed | leg_removed | round_locked | leg_result | round_settled
  legId     String?  // system pick events: the announced leg — lets the betslip row find its message
  leg       Leg?     @relation(fields: [legId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  reactions MessageReaction[]

  @@index([roundId, createdAt])
  @@index([legId])
}

model MessageReaction {
  id        String       @id @default(cuid())
  messageId String
  message   RoundMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String // constrained set — see REACTION_EMOJIS in packages/shared
  createdAt DateTime     @default(now())

  @@unique([messageId, userId, emoji])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  roundId   String?
  groupId   String?
  channel   String
  sentAt    DateTime @default(now())

  @@unique([userId, type, roundId, channel])
  @@index([roundId])
}
